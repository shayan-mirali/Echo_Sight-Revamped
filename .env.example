# Copy to .env and adjust. .env is gitignored.

# --- Database (Postgres) ---
# Local: `docker compose up -d` then use the URL below.
# Prod: a managed Postgres URL (Render/Neon), usually with ?sslmode=require.
DATABASE_URL="postgresql://echo:echo@localhost:5432/echosight?schema=public"

# --- Server ---
PORT=3000
# "production" enables the boot-time config guard (rejects dev secrets / open
# CORS / SQLite) and stops OTP codes being logged. Leave unset/"development" locally.
NODE_ENV=development

# --- CORS ---
# Comma-separated allowed origins, or "*" for any (dev only). In production set
# this to your app/web origins, e.g. "https://app.echosight.example".
CORS_ORIGIN=*
# Set to "true" when running behind a reverse proxy (nginx, Cloud Run, etc.) so
# the rate limiter reads the real client IP from X-Forwarded-For.
TRUST_PROXY=false

# --- Realtime audio limits (WebSocket /sound) ---
# Max bytes for a single audio frame message (transport-level cap).
WS_MAX_FRAME_BYTES=262144
# Max audio frames a single connection may send per second (anti-flood).
WS_MAX_FRAMES_PER_SEC=30

# --- JWT ---
# Generate strong random values in production, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_ACCESS_TTL="15m"
# Refresh token lifetime (days)
REFRESH_TTL_DAYS=30

# --- OTP ---
OTP_TTL_MINUTES=10

# --- Email (SMTP) for OTP delivery ---
# If unset, OTP codes are logged to the console in dev (and not sent in prod).
# Port 465 = implicit TLS; 587 = STARTTLS.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
